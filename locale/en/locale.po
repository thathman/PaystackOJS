msgid "plugins.paymethod.paystack.settings.callbackUrl"
msgstr "Callback URL"

msgid "plugins.paymethod.paystack.settings.callbackUrl.description"
msgstr "Paystack redirects users to this URL after payment completion. Copy this URL and add it to your Paystack Dashboard → Settings → API Keys & Webhooks → Callback URL."

msgid "plugins.paymethod.paystack.settings.webhookUrl"
msgstr "Webhook URL"

msgid "plugins.paymethod.paystack.settings.webhookUrl.description"
msgstr "Paystack sends payment events to this URL via POST. Copy this URL and add it to your Paystack Dashboard → Settings → API Keys & Webhooks → Webhook URL. Webhooks provide reliable server-to-server notifications."

msgid "plugins.paymethod.paystack.settings.createCustomerOnPaid"
msgstr "Create/Update Paystack customer on successful payment"

msgid "plugins.paymethod.paystack.settings.createCustomerOnPaid.description"
msgstr "When enabled, the plugin will ensure a Paystack customer record exists for the paying user, storing the customer code for future features (e.g., saved authorizations)."

msgid "plugins.paymethod.paystack.settings.sendConfirmationEmail"
msgstr "Send Confirmation Email to User"

msgid "plugins.paymethod.paystack.settings.sendConfirmationEmail.description"
msgstr "When enabled, users will receive an email confirmation with payment details after successful payment."

msgid "plugins.paymethod.paystack.settings.sendAdminNotification"
msgstr "Send Notification Email to Administrators"

msgid "plugins.paymethod.paystack.settings.sendAdminNotification.description"
msgstr "When enabled, journal managers and subscription managers will receive an email notification when a payment is completed."

msgid "plugins.paymethod.paystack.settings.autoEmailOnWebhookFailure"
msgstr "Auto-Email on Webhook Failure"

msgid "plugins.paymethod.paystack.settings.autoEmailOnWebhookFailure.description"
msgstr "When enabled, administrators will receive an email notification if a webhook verification fails or payment processing encounters an error."

msgid "plugins.paymethod.paystack.settings.allowedCurrencies"
msgstr "Allowed Currencies"

msgid "plugins.paymethod.paystack.settings.allowedCurrencies.description"
msgstr "Comma-separated list of currency codes that are allowed for payments (e.g., NGN,USD,EUR,GBP). Leave empty to allow all supported currencies."

msgid "plugins.paymethod.paystack.settings.testModeBannerEnabled"
msgstr "Show Test Mode Banner"

msgid "plugins.paymethod.paystack.settings.testModeBannerEnabled.description"
msgstr "When enabled, a warning banner will be displayed to administrators when test mode is active."

msgid "plugins.paymethod.paystack.settings.logLevel"
msgstr "Error Log Level"

msgid "plugins.paymethod.paystack.settings.logLevel.description"
msgstr "Select the minimum log level to record. Lower levels include higher levels (e.g., WARNING includes ERROR and CRITICAL)."

msgid "plugins.paymethod.paystack.settings.logLevel.debug"
msgstr "DEBUG - All events (detailed debugging)"

msgid "plugins.paymethod.paystack.settings.logLevel.info"
msgstr "INFO - Informational events (recommended)"

msgid "plugins.paymethod.paystack.settings.logLevel.warning"
msgstr "WARNING - Warning events and above (default)"

msgid "plugins.paymethod.paystack.settings.logLevel.error"
msgstr "ERROR - Error events and above"

msgid "plugins.paymethod.paystack.settings.logLevel.critical"
msgstr "CRITICAL - Critical events only"

