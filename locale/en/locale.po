msgid "plugins.paymethod.paystack.displayName"
msgstr "Paystack Payment Gateway"

msgid "plugins.paymethod.paystack.description"
msgstr "Payments will be processed using the Paystack payment gateway."

msgid "plugins.paymethod.paystack"
msgstr "Paystack Fee Payment"

msgid "plugins.paymethod.paystack.settings"
msgstr "Paystack Payment Settings"

msgid "plugins.paymethod.paystack.settings.description"
msgstr "Configure your Paystack payment gateway settings including API keys, test mode, email notifications, and currency restrictions."

msgid "plugins.paymethod.paystack.settings.testMode"
msgstr "Test Mode"

msgid "plugins.paymethod.paystack.settings.testMode.description"
msgstr "When enabled, the plugin will use test API keys. Test mode transactions will not process real payments."

msgid "plugins.paymethod.paystack.settings.testPublicKey"
msgstr "Test Public Key"

msgid "plugins.paymethod.paystack.settings.testPublicKey.description"
msgstr "Your Paystack test public key (starts with pk_test_). Get this from your Paystack Dashboard → Settings → API Keys & Webhooks."

msgid "plugins.paymethod.paystack.settings.testSecretKey"
msgstr "Test Secret Key"

msgid "plugins.paymethod.paystack.settings.testSecretKey.description"
msgstr "Your Paystack test secret key (starts with sk_test_). Get this from your Paystack Dashboard → Settings → API Keys & Webhooks."

msgid "plugins.paymethod.paystack.settings.livePublicKey"
msgstr "Live Public Key"

msgid "plugins.paymethod.paystack.settings.livePublicKey.description"
msgstr "Your Paystack live public key (starts with pk_live_). Get this from your Paystack Dashboard → Settings → API Keys & Webhooks. Only use in production!"

msgid "plugins.paymethod.paystack.settings.liveSecretKey"
msgstr "Live Secret Key"

msgid "plugins.paymethod.paystack.settings.liveSecretKey.description"
msgstr "Your Paystack live secret key (starts with sk_live_). Get this from your Paystack Dashboard → Settings → API Keys & Webhooks. Only use in production!"

msgid "plugins.paymethod.paystack.settings.secretKeyMasked"
msgstr "The current key is masked for security. Enter a new key to update, or leave it as-is to keep the current value."

msgid "plugins.paymethod.paystack.testMode.banner.message"
msgstr "⚠️ Paystack Payment Gateway is currently in TEST MODE. All transactions will use test keys and no real payments will be processed."

msgid "plugins.paymethod.paystack.settings.publicKey"
msgstr "Public Key"

msgid "plugins.paymethod.paystack.settings.publicKey.description"
msgstr "Your Paystack public key (starts with pk_test_ or pk_live_)"

msgid "plugins.paymethod.paystack.settings.secretKey"
msgstr "Secret Key"

msgid "plugins.paymethod.paystack.settings.secretKey.description"
msgstr "Your Paystack secret key (starts with sk_test_ or sk_live_)"

msgid "plugins.paymethod.paystack.settings.supportedCurrencies"
msgstr "Supported Currencies"

msgid "plugins.paymethod.paystack.settings.supportedCurrencies.description"
msgstr "Paystack supports the following currencies for payments. Ensure your journal's currency is set to one of these supported currencies in the journal settings."

msgid "plugins.paymethod.paystack.error"
msgstr "A transaction error occurred. Please contact the journal manager for details."

msgid "plugins.paymethod.paystack.error.httpsRequired"
msgstr "HTTPS is required for payments. Enable SSL or switch to Test Mode."

