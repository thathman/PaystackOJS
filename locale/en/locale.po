# Email Templates
msgid "emails.paystack.paymentConfirmation.subject"
msgstr "Paystack Payment Received — {$contextName}"

msgid "emails.paystack.paymentConfirmation.body"
msgstr "<p>Dear {$recipientName},</p><p>We have received your payment of <strong>{$paymentAmount} {$paymentCurrency}</strong>.</p><p>Reference: <strong>{$paymentReference}</strong><br>Date: {$paymentDate}</p><p>You can return to your workflow here: <a href=\"{$paymentUrl}\">{$paymentUrl}</a></p><p>Regards,<br>{$contextName}</p>"

msgid "emails.paystack.paymentConfirmationAdmin.subject"
msgstr "Paystack — New Payment Received — {$paymentReference}"

msgid "emails.paystack.paymentConfirmationAdmin.body"
msgstr "<p>Hello {$managerName},</p><p>A new payment of <strong>{$paymentAmount} {$paymentCurrency}</strong> has been completed.</p><p><strong>Reference:</strong> {$paymentReference}<br><strong>Payer:</strong> {$payerName} ({$payerEmail})<br><strong>Submission:</strong> {$submissionTitle}</p><p>You can view the transaction details here: <a href=\"{$paymentManagementUrl}\">Payment Management</a></p><p>Regards,<br>{$contextName}</p>"

msgid "mailable.paystack.paymentFailed.name"
msgstr "Paystack Payment Failed"

msgid "mailable.paystack.paymentFailed.description"
msgstr "Email sent to the payer when a payment attempt fails."

msgid "emails.paystack.paymentFailed.subject"
msgstr "Payment Failed — {$contextName}"

msgid "emails.paystack.paymentFailed.body"
msgstr "<p>Dear {$recipientName},</p><p>Your payment attempt for <strong>{$paymentAmount} {$paymentCurrency}</strong> was not successful.</p><p>Reference: <strong>{$paymentReference}</strong><br>Date: {$paymentDate}</p><p>Please try again or contact the journal if the issue persists.</p><p>Regards,<br>{$contextName}</p>"

